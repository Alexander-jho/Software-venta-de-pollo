// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("EMPLEADO") // ADMIN, EMPLEADO
  createdAt DateTime @default(now())
}

model Product {
  id           String   @id @default(cuid())
  name         String
  sku          String   @unique
  category     String?  // POLLO_ENTERO, DESPRESADO, etc.
  unit         String   @default("KG")
  currentStock Float    @default(0)
  costPrice    Float    @default(0)
  sellingPrice Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  transactions InventoryTransaction[]
  saleItems    SaleItem[]
  purchaseItems PurchaseItem[]
}

model InventoryTransaction {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String   // PURCHASE, SALE, PRODUCTION_IN, PRODUCTION_OUT, ADJUSTMENT
  quantity  Float
  price     Float
  date      DateTime @default(now())
  referenceId String? // ID of the sale, purchase or production record
}

model Purchase {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  supplierName  String
  date          DateTime @default(now())
  total         Float
  paymentType   String   // CONTADO, CREDITO
  status        String   @default("COMPLETED") // PENDING, COMPLETED
  
  items         PurchaseItem[]
  createdAt     DateTime @default(now())
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Float
  unitPrice  Float
  totalPrice Float
}

model Sale {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  customerName  String
  date          DateTime @default(now())
  total         Float
  paymentType   String   // CONTADO, CREDITO
  status        String   @default("COMPLETED")
  
  items         SaleItem[]
  createdAt     DateTime @default(now())
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Float
  unitPrice  Float
  totalPrice Float
}

model Production {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  inputProductId String
  inputQuantity  Float
  costPerKg      Float    // Recorded cost at time of production
  
  createdAt      DateTime @default(now())
}

model CashTransaction {
  id          String   @id @default(cuid())
  type        String   // INCOME, EXPENSE
  amount      Float
  description String
  category    String?  // VENTA, COMPRA, ADELANTO, OTRO
  date        DateTime @default(now())
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  position  String
  salary    Float
  advances  Float    @default(0)
  createdAt DateTime @default(now())
}
